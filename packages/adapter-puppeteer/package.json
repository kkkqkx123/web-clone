{
  "name": "@web-clone/adapter-puppeteer",
  "version": "1.0.2",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kkkqkx123/web-clone.git"
  },
  "homepage": "https://github.com/kkkqkx123/web-clone#readme",
  "bugs": {
    "url": "https://github.com/kkkqkx123/web-clone/issues"
  },
  "keywords": [
    "puppeteer",
    "browser",
    "automation",
    "snapshot",
    "web-clone"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@web-clone/core": "workspace:*",
    "@web-clone/adapter-common": "workspace:*",
    "puppeteer": "^25.3.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  }
