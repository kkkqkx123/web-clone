{
  "name": "@web-clone/core",
  "version": "1.0.2",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./adapters": "./dist/adapters/index.js",
    "./server": "./dist/server/index.js",
    "./types": "./dist/types.js",
    "./config": "./dist/config/schema.js"
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kkkqkx123/web-clone.git"
  },
  "homepage": "https://github.com/kkkqkx123/web-clone#readme",
  "bugs": {
    "url": "https://github.com/kkkqkx123/web-clone/issues"
  },
  "keywords": [
    "webpage",
    "snapshot",
    "archive",
    "scraper",
    "html",
    "web-clone"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:unit": "vitest run src/__tests__",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@babel/parser": "^8.0.4",
    "@babel/traverse": "^8.0.4",
    "@babel/types": "^8.0.4",
    "@web-clone/codegen": "workspace:*",
    "@web-clone/types": "workspace:*",
    "css-tree": "^3.2.1",
    "global-agent": "^4.1.3",
    "http-proxy-agent": "^9.1.0",
    "https-proxy-agent": "^9.1.0",
    "node-fetch-native": "^1.6.7",
    "postcss": "^8.5.17"
  },
  "peerDependencies": {
    "jsdom": "^29.0.0"
  },
  "peerDependenciesMeta": {
    "jsdom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/css-tree": "^2.3.11",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "jsdom": "^29.1.1"
  }
}
