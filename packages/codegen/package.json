{
  "name": "@web-clone/codegen",
  "version": "1.0.4",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vue": {
      "types": "./dist/vue-generator.d.ts",
      "default": "./dist/vue-generator.js"
    },
    "./react": {
      "types": "./dist/react-generator.d.ts",
      "default": "./dist/react-generator.js"
    },
    "./angular": {
      "types": "./dist/angular-generator.d.ts",
      "default": "./dist/angular-generator.js"
    },
    "./svelte": {
      "types": "./dist/svelte-generator.d.ts",
      "default": "./dist/svelte-generator.js"
    },
    "./jquery": {
      "types": "./dist/jquery-generator.d.ts",
      "default": "./dist/jquery-generator.js"
    }
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kkkqkx123/web-clone.git"
  },
  "homepage": "https://github.com/kkkqkx123/web-clone#readme",
  "bugs": {
    "url": "https://github.com/kkkqkx123/web-clone/issues"
  },
  "keywords": [
    "vue",
    "react",
    "angular",
    "svelte",
    "jquery",
    "code-generator",
    "web-clone"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@web-clone/types": "workspace:*",
    "@babel/parser": "^8.0.4",
    "@babel/traverse": "^8.0.4",
    "@babel/types": "^8.0.4"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^26.1.1"
  }
}
