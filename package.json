{
  "name": "web-clone",
  "version": "1.0.0",
  "description": "Single-execution web page snapshot tool based on MirrorKit",
  "type": "module",
  "bin": {
    "snapshot": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "snapshot": "tsx src/cli.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "@babel/parser": "^8.0.4",
    "@babel/traverse": "^8.0.4",
    "@babel/types": "^8.0.4",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "css-tree": "^3.2.1",
    "global-agent": "^4.1.3",
    "http-proxy-agent": "^9.1.0",
    "https-proxy-agent": "^9.1.0",
    "linkedom": "^0.18.13",
    "node-fetch-native": "^1.6.7",
    "ora": "^9.4.1",
    "postcss": "^8.5.16"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/babel__parser": "^7.0.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/css-tree": "^2.3.11",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}